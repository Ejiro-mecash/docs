{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "meCash Documentation",
  "api": {
    "playground": {
      "proxy": false
    },
    "path": "api-reference/openapi.json",
    "baseUrl": [
      {
        "name": "Sandbox",
        "url": "https://sandboxapi.me-cash.com"
      }
    ],
    "examples": {
      "languages": [
        "javascript",
        "curl",
        "python",
        "nodejs",
        "php",
        "java",
        "ruby",
        "swift",
        "kotlin",
        "rust",
        "go",
        "scala",
        "erlang"
      ]
    }
  },
  "ai": {
    "name": "meCash",
    "context": true
  },
  "appearance": {
    "default": "dark"
  },
  "backgroundImage": {
    "dark": "/background-dark.svg"
  },
  "colors": {
    "primary": "#240552",
    "light": "#B692F6",
    "dark": "#240552"
  },
  "favicon": "/favicon/mecashlogo.png",
  "navigation": {
